{
  "name": "multiview-web",
  "private": true,
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "description": "Multiview management web app. Minimal real app shell: TanStack Query + a typed API client generated from the control-plane OpenAPI spec (openapi-typescript + openapi-fetch). The full layout editor (react-konva/dnd-kit/shadcn) is milestone M7; see ../docs/web/management-app.md.",
  "scripts": {
    "dev": "vite",
    "generate:api": "openapi-typescript ../docs/api/openapi.json -o src/api/schema.ts",
    "generate:events": "node scripts/gen-events-types.mjs",
    "build": "lingui compile && tsc --noEmit && vite build",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/accessibility": "^3.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "konva": "^10.3.0",
    "lucide-react": "^1.24.0",
    "minisearch": "^7.2.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.5",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lingui/babel-plugin-lingui-macro": "^6.5.0",
    "@lingui/cli": "^6.5.0",
    "@lingui/format-po": "^6.4.0",
    "@lingui/vite-plugin": "^6.5.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-macros": "^3.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    },
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  }
}
