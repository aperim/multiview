{
  "name": "multiview-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Multiview management web app. Minimal real app shell: TanStack Query + a typed API client generated from the control-plane OpenAPI spec (openapi-typescript + openapi-fetch). The full layout editor (react-konva/dnd-kit/shadcn) is milestone M7; see ../docs/web/management-app.md.",
  "scripts": {
    "dev": "vite",
    "generate:api": "openapi-typescript ../docs/api/openapi.json -o src/api/schema.ts",
    "generate:events": "node scripts/gen-events-types.mjs",
    "build": "lingui compile && tsc --noEmit && vite build",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/accessibility": "^3.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lingui/core": "^5.9.5",
    "@lingui/react": "^5.9.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "konva": "^9.3.22",
    "lucide-react": "^0.460.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.4",
    "react-router-dom": "^7.16.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@lingui/babel-plugin-lingui-macro": "^5.9.5",
    "@lingui/cli": "^5.9.5",
    "@lingui/vite-plugin": "^5.9.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-macros": "^3.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^25.0.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.7",
    "vitest": "^4.1.8"
  }
}
