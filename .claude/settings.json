{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "deny": [
      "Read(/.env)",
      "Read(/.env.*)",
      "Read(/.memory/**)",
      "Read(/**/target/**)",
      "Read(/**/node_modules/**)",
      "Read(/**/dist/**)",
      "Read(/.multiview-build/**)",
      "Read(/.ndi-sdk/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Persistent project memory is active: recall prior decisions with qdrant-find before non-trivial work; store new decisions, corrections and gotchas with qdrant-store (conventions: the memory skill). Work in a worktree lane, not the root checkout (worktree-lane skill).'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-worktree.mjs\""
          }
        ]
      }
    ]
  }
}
