# Rust
/target
**/*.rs.bk
*.pdb

# Cargo — Cargo.lock IS committed (this workspace ships the `multiview` binary)

# Build working dir (transient research/build artifacts — not part of the product)
/.multiview-build/

# Proprietary NDI SDK drop-spot (NewTek/Vizrt; NEVER vendored/committed — ADR-0008).
# The operator places the licensed SDK tarball here; it is extracted into the
# image/container at build time and never enters git history.
/.ndi-sdk/

# Web / Node
web/node_modules/
web/dist/
node_modules/
dist/
*.local

# Editors / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Logs / runtime
*.log
/data/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Secrets / env
.env
.env.*
!.env.example

# Per-host, uncommitted dev container override (e.g. VAAPI /dev/dri device + render GID)
.devcontainer/devcontainer.local.json

# Demo/multiview screenshots for manual inspection (not part of the product)
/demo-output/

# Coding-agent working directory. Most of it is local scratch (sessions, locks,
# worktree lanes, per-host settings) and is NOT part of the product — but the
# committed governance machinery IS (ADR-G006): settings.json, skills/, hooks/.
# Ignore the contents, then re-include the three committed paths. (You cannot
# negate a child if the parent dir itself is ignored, so we ignore `/.claude/*`.)
/.claude/*
!/.claude/settings.json
!/.claude/skills/
!/.claude/hooks/

# Local persistent memory MCP store (embedded qdrant + embedding-model cache) —
# never commit (ADR-G006).
/.memory/

# Manual worktree lanes (alt location to .claude/worktrees/) — disposable.
/.worktrees/

demo-output/
