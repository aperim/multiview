# Mosaic environment template.
#
# Copy to `.env` (gitignored) OR let the dev container seed it automatically:
# `.devcontainer/initialize.sh` runs on the HOST and, if ~/.onepassword_token
# exists, writes OP_SERVICE_ACCOUNT_TOKEN below for you. It always creates `.env`
# (empty if no token) so the container's `--env-file .env` never fails.
#
# NEVER commit real secret values. `.env` and `.env.*` are gitignored; only this
# `.env.example` is tracked.

# --- 1Password ---------------------------------------------------------------
# Service account token. Authenticates the `op` CLI non-interactively inside the
# container so app/tests can read other credentials:
#   op read "op://Claude API Access/GitHub API - Personal/token"
# Leave blank to disable op (build/test still work without it).
OP_SERVICE_ACCOUNT_TOKEN=

# Do NOT set OP_CONNECT_HOST / OP_CONNECT_TOKEN here: if present they OVERRIDE the
# service-account token and break op auth in the container.

# --- Logging -----------------------------------------------------------------
# Rust tracing/env-filter level (e.g. info, debug, mosaic=debug,wgpu=warn).
RUST_LOG=info

# --- GPU / codecs (optional overrides; sane defaults applied by the container) -
# Forces a specific VAAPI driver when auto-detection is wrong (iHD | i965 | radeonsi).
# LIBVA_DRIVER_NAME=iHD
#
# NVIDIA capabilities are set in devcontainer.json containerEnv
# (NVIDIA_DRIVER_CAPABILITIES=compute,utility,video). Override only if you must.
# NVIDIA_DRIVER_CAPABILITIES=all
